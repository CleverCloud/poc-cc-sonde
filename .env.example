# Example environment variables for POC Sonde
# Copy this file to .env and customize for your environment

# Redis Configuration (for state persistence)
# Option 1: Use a complete Redis URL
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:mypassword@localhost:6379

# Option 2: Use separate Redis configuration variables
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=mypassword

# WarpScript Configuration (required for WarpScript probes)
# WARP_ENDPOINT=https://warp.example.com/api/v0/exec
# WARP_TOKEN=YOUR_READ_TOKEN_HERE

# Logging configuration
# RUST_LOG=poc_sonde=debug
# RUST_LOG=info
